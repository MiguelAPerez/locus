# Locus configuration
# Copy to .env and adjust as needed

# Port Locus listens on (host side)
LOCUS_PORT=8000

# Authentication (optional)
AUTH_ENABLED=true
REGISTRATION_ENABLED=true
SECRET_KEY=  # Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=password1

# URL of your external Ollama instance
# Defaults to host machine's Ollama when running in Docker
OLLAMA_URL=http://host.docker.internal:11434

# Embedding model — must already be available in your Ollama instance
EMBED_MODEL=nomic-embed-text
