# Locus configuration
# Copy to .env and adjust as needed

# Port Locus listens on (host side)
LOCUS_PORT=8000

# Port Ollama listens on (host side)
OLLAMA_PORT=11434

# Embedding model (must be pulled in Ollama first)
# docker exec locus-ollama ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text
